<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  PHASE 2 of 2 — Apex, triggers, LWC, permission sets.
  Deploy this ONLY AFTER Phase 1 (package-cadence-datamodel.xml) is committed
  AND the Activity fields have reflected onto Task/Event in prod
  (verify: SELECT Is_Sequence_Call__c FROM Task LIMIT 1 no longer errors).

  Deploy / validate:
    sf project deploy start --manifest manifest/package-cadence-apex.xml \
      --target-org BlueSkyProduction --test-level RunLocalTests

  FLS NOTE: the RunLocalTests run uses USER_MODE DML on the Task cadence fields.
  The deploying/test user must have edit FLS on Task.Is_Sequence_Call__c /
  Sequence_Step__c. If tests report "fields inaccessible on Task" AFTER the
  fields are confirmed reflected, assign Login_Sequence_User (deployed below) to
  the running user, or grant that FLS on the System Administrator profile, then
  re-run.
-->
<Package xmlns="http://soap.sforce.com/2006/04/metadata">

    <!-- Apex classes (12) + test classes (7) -->
    <types>
        <members>TargetSelector</members>
        <members>TaskSelector</members>
        <members>ContentSelector</members>
        <members>SequenceStepConfigService</members>
        <members>SequenceEmailService</members>
        <members>SequenceEngineService</members>
        <members>TargetTriggerHandler</members>
        <members>TaskTriggerHandler</members>
        <members>SequenceStartQueueable</members>
        <members>SequenceSchedulerBatch</members>
        <members>SequenceSchedulerSchedulable</members>
        <members>SequenceAttachmentController</members>
        <members>SequenceEmailServiceTest</members>
        <members>SequenceEngineServiceTest</members>
        <members>SequenceSelectorsTest</members>
        <members>TargetTriggerHandlerTest</members>
        <members>TaskTriggerHandlerTest</members>
        <members>SequenceSchedulerBatchTest</members>
        <members>SequenceAttachmentControllerTest</members>
        <members>TaskTargetControllerTest</members>
        <name>ApexClass</name>
    </types>

    <!-- Triggers (one per object) -->
    <types>
        <members>TargetTrigger</members>
        <members>TaskTrigger</members>
        <name>ApexTrigger</name>
    </types>

    <!-- LWC (depends on SequenceAttachmentController + the labels from Phase 1) -->
    <types>
        <members>targetEmailAttachment</members>
        <name>LightningComponentBundle</name>
    </types>

    <!-- Permission sets (reference SequenceAttachmentController classAccess + reflected Task/Event FLS) -->
    <types>
        <members>Login_Sequence_Admin</members>
        <members>Login_Sequence_User</members>
        <name>PermissionSet</name>
    </types>

    <version>66.0</version>
</Package>
